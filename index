<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RIMAN | Demo Premium</title>
  <meta name="description" content="Landing demo premium RIMAN" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="container header-container">
      <img src="images/logo-riman.png" class="logo" alt="Logo RIMAN" />

      <nav class="menu">
        <a href="#about">Nosotros</a>
        <a href="#gift">Bono</a>
        <a href="#register">Registro</a>
        <a href="#products">Productos</a>
        <a href="#videos">Vídeos</a>
        <a href="#contact">Contacto</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>

    <div class="container hero-grid">
      <div class="hero-copy" data-aos="fade-up" data-aos-duration="1000">
        <p class="eyebrow">Skincare premium · bienestar · belleza</p>
        <h1>Descubre una experiencia elegante de cuidado con RIMAN</h1>
        <p class="hero-text">
          Una landing pensada para presentar vuestra imagen, captar registros,
          ofrecer un bono de bienvenida y guiar a cada persona hacia su asesor RIMAN.
        </p>

        <div class="hero-actions">
          <a href="#register" class="btn btn-dark">Registrarme</a>
          <a href="#products" class="btn btn-light">Ver productos</a>
        </div>
      </div>

      <div class="hero-visual" data-aos="fade-left" data-aos-duration="1200">
        <div class="visual-frame">
          <img src="images/firas.png" class="hero-img" alt="Imagen principal skincare" />
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section section-soft">
    <div class="container split-grid">
      <div class="text-column" data-aos="fade-right">
        <p class="section-tag">Sobre nosotros</p>
        <h2>Asesoría personalizada con una imagen más premium y cuidada</h2>
        <p>
          Esta sección está pensada para presentar quiénes sois, transmitir confianza
          y dar una imagen elegante, limpia y profesional.
        </p>
        <p>
          Aquí podéis contar brevemente vuestra historia, vuestra forma de ayudar a
          los clientes y el valor diferencial de comprar a través de vuestro acompañamiento.
        </p>
      </div>

      <div class="media-column" data-aos="fade-left">
        <img src="images/producto1.png" class="side-image" alt="Producto destacado" />
      </div>
    </div>
  </section>

  <!-- GIFT -->
  <section id="gift" class="section">
    <div class="container">
      <div class="gift-panel" data-aos="zoom-in">
        <div class="gift-copy">
          <p class="section-tag">Bono regalo</p>
          <h2>Regístrate y recibe una bienvenida especial</h2>
          <p>
            Esta sección sirve para reforzar el valor del registro, captar atención
            y aumentar las conversiones con una propuesta clara.
          </p>
        </div>

        <div class="gift-card">
          <span class="gift-small">WELCOME</span>
          <strong>BONO REGALO</strong>
          <span class="gift-small">por registro</span>
        </div>
      </div>
    </div>
  </section>

  <!-- REGISTER -->
  <section id="register" class="section section-dark">
    <div class="container">
      <div class="center-intro" data-aos="fade-up">
        <p class="section-tag light-tag">Registro</p>
        <h2>Obtén acceso y elige tu persona RIMAN</h2>
        <p>
          Este formulario se podrá conectar más adelante con la base de datos y el
          envío automático del email de bienvenida.
        </p>
      </div>

      <div class="form-card" data-aos="fade-up" data-aos-delay="120">
        <form class="premium-form">
          <div class="form-row">
            <div class="field">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" placeholder="Tu nombre" />
            </div>

            <div class="field">
              <label for="email">Email</label>
              <input type="email" id="email" placeholder="Tu email" />
            </div>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="ciudad">Ciudad</label>
              <input type="text" id="ciudad" placeholder="Tu ciudad" />
            </div>

            <div class="field">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" placeholder="Tu teléfono" />
            </div>
          </div>

          <div class="field">
            <label for="asesor">Elige tu persona RIMAN</label>
            <select id="asesor">
              <option>Selecciona una opción</option>
              <option>Socio 1</option>
              <option>Socio 2</option>
            </select>
          </div>

          <button class="btn btn-gold" type="submit">Obtener acceso</button>
        </form>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products" class="section section-soft">
    <div class="container">
      <div class="center-intro" data-aos="fade-up">
        <p class="section-tag">Selección de productos</p>
        <h2>Una presentación visual limpia y elegante</h2>
        <p>
          Aquí se muestran los productos con una estética más premium y moderna.
        </p>
      </div>

      <div class="product-grid">
        <article class="product-item" data-aos="fade-up">
          <img src="images/producto1.png" class="product-img" alt="Producto RIMAN 1" />
          <h3>Línea Skincare</h3>
          <p>Productos premium para el cuidado diario de la piel.</p>
        </article>

        <article class="product-item" data-aos="fade-up" data-aos-delay="80">
          <img src="images/producto2.png" class="product-img" alt="Producto RIMAN 2" />
          <h3>Protección Solar</h3>
          <p>Protección, hidratación y cuidado con un acabado elegante.</p>
        </article>

        <article class="product-item" data-aos="fade-up" data-aos-delay="160">
          <img src="images/producto1.png" class="product-img" alt="Producto RIMAN 3" />
          <h3>Rutina Facial</h3>
          <p>Una rutina pensada para una piel sana, luminosa y cuidada.</p>
        </article>

        <article class="product-item" data-aos="fade-up">
          <img src="images/producto2.png" class="product-img" alt="Producto RIMAN 4" />
          <h3>Hidratación</h3>
          <p>Texturas suaves y cuidado profundo con una imagen premium.</p>
        </article>

        <article class="product-item" data-aos="fade-up" data-aos-delay="80">
          <img src="images/producto1.png" class="product-img" alt="Producto RIMAN 5" />
          <h3>Cuidado Premium</h3>
          <p>Experiencia skincare de alta calidad con estilo limpio y sofisticado.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- VIDEOS -->
  <section id="videos" class="section">
    <div class="container">
      <div class="center-intro" data-aos="fade-up">
        <p class="section-tag">Vídeos</p>
        <h2>Contenido dinámico para reforzar la experiencia</h2>
        <p>
          Vídeos pensados para mostrar producto, marca y oportunidad.
        </p>
      </div>

      <div class="video-grid">
        <div class="video-item" data-aos="fade-up">
          <video class="video-real" controls autoplay muted loop playsinline>
            <source src="videos/video1.mp4" type="video/mp4" />
            Tu navegador no soporta vídeo HTML5.
          </video>
        </div>

        <div class="video-item" data-aos="fade-up" data-aos-delay="100">
          <video class="video-real" controls autoplay muted loop playsinline>
            <source src="videos/video2.mp4" type="video/mp4" />
            Tu navegador no soporta vídeo HTML5.
          </video>
        </div>

        <div class="video-item" data-aos="fade-up" data-aos-delay="200">
          <img src="images/producto2.png" class="video-real" alt="Visual de apoyo" />
        </div>
      </div>
    </div>
  </section>

  <!-- OPPORTUNITY -->
  <section class="section section-soft">
    <div class="container cta-strip" data-aos="fade-up">
      <div>
        <p class="section-tag">Oportunidad</p>
        <h2>¿Te interesa trabajar con nosotros y generar ingresos con RIMAN?</h2>
        <p>
          También se puede incluir una vía directa para personas interesadas en unirse al equipo.
        </p>
      </div>
      <a href="#" class="btn btn-dark">Hablar por WhatsApp</a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section section-dark">
    <div class="container">
      <div class="center-intro" data-aos="fade-up">
        <p class="section-tag light-tag">Contacto</p>
        <h2>Estamos aquí para acompañarte</h2>
        <p>
          Puedes usar esta sección para WhatsApp, email y llamadas a la acción finales.
        </p>
      </div>

      <div class="contact-row">
        <div class="contact-box" data-aos="fade-up">
          <h3>WhatsApp</h3>
          <p>Asesoría directa y personalizada.</p>
        </div>

        <div class="contact-box" data-aos="fade-up" data-aos-delay="100">
          <h3>Email</h3>
          <p>Consultas, seguimiento y atención.</p>
        </div>

        <div class="contact-box" data-aos="fade-up" data-aos-delay="200">
          <h3>Registro</h3>
          <p>Acceso, bono y contacto.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <p>Demo visual de landing premium RIMAN</p>
      <p>Preparada para presentación al cliente</p>
    </div>
  </footer>

  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script>
    AOS.init({
      duration: 900,
      once: true,
      offset: 80
    });
  </script>
</body>
</html>
